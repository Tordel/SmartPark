@page "/spaces"
@using SmartPark.Frontend.Models
@using SmartPark.Frontend.Services
@inject ParkingSpaceService ParkingSpaceService
@inject NavigationManager Navigation

<div class="spaces-page">
    <h1>Parking Spaces</h1>

    <div class="filters">
        <select @onchange="OnStatusFilterChanged">
            <option value="">All Statuses</option>
            <option value="free">Free</option>
            <option value="occupied">Occupied</option>
            <option value="reserved">Reserved</option>
        </select>
        <input type="text" placeholder="Search space number..." 
               value="@searchTerm" @oninput="OnSearchChanged" />
    </div>

    @if (filteredSpaces == null)
    {
        <div class="loading">Loading parking spaces...</div>
    }
    else if (!filteredSpaces.Any())
    {
        <div class="no-data">No parking spaces found</div>
    }
    else
    {
        <div class="spaces-grid">
            @foreach (var space in filteredSpaces)
            {
                <div class="space-card @GetStatusClass(space.Status)" @onclick="() => GoToSpaceDetails(space.Id)">
                    <div class="space-number">@space.SpaceNumber</div>
                    <div class="space-status">Status: @space.Status</div>
                    <div class="space-type">@space.Type</div>
                    <div class="space-rate">@space.HourlyRate RON / hour</div>
                    <div class="space-updated">Updated @GetTimeAgo(space.LastDetectedAt)</div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<ParkingSpaceDto>? allSpaces;
    private List<ParkingSpaceDto>? filteredSpaces;
    private string selectedStatus = "";
    private string searchTerm = "";

    protected override async Task OnInitializedAsync()
    {
        var paginatedData = await ParkingSpaceService.GetAllParkingSpacesAsync(1, 100);
        if (paginatedData != null)
        {
            allSpaces = paginatedData.Items;
            ApplyFilters();
        }
    }

    private async Task OnStatusFilterChanged(ChangeEventArgs e)
    {
        selectedStatus = e.Value?.ToString() ?? "";
        ApplyFilters();
    }

    private void OnSearchChanged(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? "";
        ApplyFilters();
    }

    private void ApplyFilters()
    {
        filteredSpaces = allSpaces?.Where(s =>
            (string.IsNullOrEmpty(selectedStatus) || s.Status.ToLower() == selectedStatus) &&
            (string.IsNullOrEmpty(searchTerm) || s.SpaceNumber.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
        ).ToList();
    }

    private string GetStatusClass(string status) => status.ToLower() switch
    {
        "free" => "free",
        "occupied" => "occupied",
        "reserved" => "reserved",
        _ => "unknown"
    };

    private string GetTimeAgo(DateTime? dateTime)
    {
        if (dateTime == null) return "never";
        var timeSpan = DateTime.UtcNow - dateTime.Value;
        if (timeSpan.TotalSeconds < 60)
            return "just now";
        if (timeSpan.TotalMinutes < 60)
            return $"{(int)timeSpan.TotalMinutes}m ago";
        if (timeSpan.TotalHours < 24)
            return $"{(int)timeSpan.TotalHours}h ago";
        return $"{(int)timeSpan.TotalDays}d ago";
    }

    private void GoToSpaceDetails(Guid id)
    {
        Navigation.NavigateTo($"/space/{id}");
    }
}